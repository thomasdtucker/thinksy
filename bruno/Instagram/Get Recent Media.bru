meta {
  name: Get Recent Media
  type: http
  seq: 2
}

get {
  url: https://graph.facebook.com/{{graph_api_version}}/{{instagram_user_id}}/media
  body: none
  auth: none
}

params:query {
  fields: id,caption,media_type,timestamp,permalink
  limit: 5
  access_token: {{instagram_access_token}}
}

assert {
  res.status: eq 200
  res.body.data: isDefined
}
