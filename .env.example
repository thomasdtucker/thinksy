# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# HeyGen Video & Avatar Image Generation
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=           # Primary avatar ID — fallback when no look IDs are set
HEYGEN_AVATAR_LOOK_IDS=     # Comma-separated avatar IDs for different outfits, e.g:
                             # id_blue_blazer,id_grey_cardigan,id_cream_blouse
                             # Create each look in HeyGen > Avatars > your avatar > Add Look
                             # Videos will cycle through them: video 1 = look 1, video 2 = look 2, etc.
HEYGEN_AVATAR_GROUP_ID=     # Photo avatar group ID (from HeyGen > Photo Avatars > group)
HEYGEN_VOICE_ID=            # Voice ID (from GET /v2/voices)
HEYGEN_VIDEO_WIDTH=1080     # Output width in pixels (1080x1920 = portrait 9:16 for Reels/Shorts)
HEYGEN_VIDEO_HEIGHT=1920    # Output height in pixels
HEYGEN_AVATAR_SCALE=1.5     # Avatar scale within the frame (1.0 = default, increase to fill portrait)

# Instagram Graph API
# IMPORTANT: The access token must be a Facebook Page Access Token (starts
# with EAA...), NOT an Instagram User Token (IGAA...). Generate one at:
# https://developers.facebook.com/tools/explorer/
# Required permissions: instagram_basic, instagram_content_publish,
# pages_read_engagement, pages_show_list
GRAPH_API_VERSION=v25.0     # Facebook Graph API version (optional, default v25.0)
INSTAGRAM_USER_ID=17841400...  # Your Instagram Business Account ID
INSTAGRAM_ACCESS_TOKEN=EAA...

# YouTube Data API v3
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# Pipeline Settings
DB_PATH=./data/thinksy.db
APPROVAL_MODE=human
PUBLIC_VIDEO_HOST=https://thinksy.ai

# Google Indexing API (optional — for faster Google indexing)
GOOGLE_INDEXING_KEY_PATH=

# Local Next.js admin console (optional)
THINKSY_ADMIN_TOKEN=
THINKSY_PYTHON=./.venv/bin/python
VIDEO_STORAGE_DIR=./data/videos

# PartnerStack (optional)
PARTNERSTACK_PUBLIC_KEY=
PARTNERSTACK_SECRET_KEY=
